# Gemini API Key: Required for Gemini AI API calls.
# In Next.js, this must be prefixed with NEXT_PUBLIC_ to be accessible in the browser.
# AI Studio automatically injects this from secrets or prompts the user via the key selection dialog.
NEXT_PUBLIC_GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=
