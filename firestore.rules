rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write for the optimizations collection (used by your other apps)
    match /optimizations/{document=**} {
      allow read, write: if true;
    }

    // ===================================
    // Rules for Optic AI App
    // ===================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidPrompt(data) {
      return hasOnlyAllowedFields(['uid', 'prompt', 'mode', 'createdAt', 'thumbnailUrls']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() <= 65000 &&
             data.mode in ['single', 'essence', 'blueprint', 'enhance'] &&
             data.createdAt is timestamp &&
             (!('thumbnailUrls' in data) || (data.thumbnailUrls is list && data.thumbnailUrls.size() <= 4));
    }

    // Prompt collection 
    match /prompts/{promptId} {
      // Users can read only their own prompts
      allow read: if isOwner(resource.data.uid);
      
      // Users can create standard prompts 
      allow create: if isOwner(request.resource.data.uid) 
                    && isValidPrompt(request.resource.data) 
                    && request.resource.data.createdAt == request.time;
      
      // Prompts are mostly immutable; no updates allowed
      allow update: if false;
      
      // Users can delete their own prompts
      allow delete: if isOwner(resource.data.uid);
    }
    
    // Keep internal documents secure (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

