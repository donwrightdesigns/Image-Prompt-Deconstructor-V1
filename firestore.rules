rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: prompts
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user ID of the person who generated the prompt.
    //   - prompt: string (required, max 10000 chars) - The generated AI prompt text.
    //   - mode: string (required, 'single' or 'essence') - The mode used to generate the prompt.
    //   - createdAt: timestamp (required) - The timestamp when the prompt was generated.
    //   - thumbnailUrls: list (optional, max 4 items) - A list of thumbnail URLs for the images used.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validator for PromptHistory
    function isValidPrompt(data) {
      return hasOnlyAllowedFields(['uid', 'prompt', 'mode', 'createdAt', 'thumbnailUrls']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() <= 10000 &&
             data.mode in ['single', 'essence'] &&
             data.createdAt is timestamp &&
             (!('thumbnailUrls' in data) || (data.thumbnailUrls is list && data.thumbnailUrls.size() <= 4));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /prompts/{promptId} {
      // Users can only read their own prompts
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      
      // Users can only create prompts for themselves
      allow create: if isAuthenticated() && 
                      isValidPrompt(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid;
      
      // Prompts are immutable for now (no updates or deletes allowed by user)
      allow update, delete: if false;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
